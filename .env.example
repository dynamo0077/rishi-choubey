# Copy to .env.local and fill in. NEVER commit this file.

# Pick ONE provider. All are OpenAI-compatible.

# --- NVIDIA NIM (free tier at https://build.nvidia.com) ---
LLM_BASE_URL=https://integrate.api.nvidia.com/v1
LLM_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
LLM_MODEL=z-ai/glm-5.1

# --- Ollama (local) ---
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_API_KEY=not-needed
# LLM_MODEL=llama3.1:8b

# --- LM Studio (local) ---
# LLM_BASE_URL=http://localhost:1234/v1
# LLM_API_KEY=not-needed
# LLM_MODEL=mlx-community/llama-3.1

# --- Groq (free tier) ---
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_API_KEY=gsk_...
# LLM_MODEL=llama-3.1-70b-versatile

# --- OpenAI ---
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=sk-...
# LLM_MODEL=gpt-4o-mini